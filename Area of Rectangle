class Rectangle {
    int length, width;

    // Constructor to initialize length and width
    Rectangle(int l, int w) {
        length = l;
        width = w;
    }

    void calculateArea() {
        System.out.println("Area of Rectangle: " + (length * width));
    }
}

public class Main {
    public static void main(String[] args) {
        Rectangle rect = new Rectangle(10, 5); // Passing values to constructor
        rect.calculateArea();
    }
}
