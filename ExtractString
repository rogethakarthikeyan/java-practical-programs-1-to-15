public class ExtractString {
    public static void main(String[] args) {
        // Step 1: Define the original character string
        String text = "Programming in Java";

        // Step 2: Extract from index 15 to the end
        String part1 = text.substring(15); 

        // Step 3: Extract from index 0 up to (but not including) index 11
        String part2 = text.substring(0, 11);

        // Step 4: Print the results
        System.out.println("Part 1: " + part1); // Output: Java
        System.out.println("Part 2: " + part2); // Output: Programming
    }
}
