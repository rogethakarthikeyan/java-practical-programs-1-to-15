class Student {
    String name;
    int m1, m2, m3;

    void display() {
        int total = m1 + m2 + m3;
        System.out.println("Name: " + name + "\nTotal Marks: " + total + "/300");
    }
}

public class Marksheet {
    public static void main(String[] args) {
        Student s1 = new Student(); // Creating an Object
        s1.name = "John Doe";
        s1.m1 = 85; s1.m2 = 90; s1.m3 = 78;
        s1.display(); // Calling Method
    }
}
